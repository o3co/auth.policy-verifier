{
	"name": "@o3co/auth.policy-verifier.core",
	"version": "0.0.0",
	"license": "Apache-2.0",
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		}
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/o3co/auth.policy-verifier.git",
		"directory": "packages/core"
	},
	"scripts": {
		"prebuild": "rimraf dist",
		"build": "tsc",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"imports": {
		"#/*": {
			"development": "./src/*",
			"default": "./dist/*"
		}
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"@vitest/coverage-v8": "^4.1.6",
		"vitest": "^4.1.6"
